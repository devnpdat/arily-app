{
  "App": {
    "SelfUrl": "https://localhost:44379",
    "CorsOrigins": "https://*.Arily.com",
    "RedirectAllowedUrls": ""
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=Arily;User ID=root;Password=myPassword;"
  },
  "AuthServer": {
    "Authority": "https://localhost:44379",
    "RequireHttpsMetadata": false,
    "SwaggerClientId": "Arily_Swagger"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "xe7zeTf3oD0ikWGR"
  },
  "Redis": {
    "Configuration": "localhost:6379"
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200",
    "LogRetentionDays": 7
  },
  "ElasticApm": {
    "ServerUrl": "http://localhost:8200",
    "ServiceName": "arily-api",
    "Environment": "production",
    "TransactionSampleRate": 1.0,
    "CaptureBody": "errors",
    "CaptureHeaders": false,
    "CentralConfig": false
  },
  "AbpAuditingOptions": {
    "IsEnabled": true,
    "HideErrors": true,
    "IsEnabledForAnonymousUsers": true,
    "AlwaysLogOnException": true,
    "IsEnabledForGetRequests": true,
    "ApplicationName": "Arily Service",
    "IsEnabledLogResponse": true
  }
}
