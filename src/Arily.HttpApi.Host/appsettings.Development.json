{
  "App": {
    "SelfUrl": "https://localhost:44379",
    "CorsOrigins": "http://localhost:3000,http://localhost:4200,https://localhost:44379",
    "RedirectAllowedUrls": "http://localhost:3000,http://localhost:4200"
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=Arily;User ID=root;Password=myPassword;"
  },
  "AuthServer": {
    "Authority": "https://localhost:44379",
    "RequireHttpsMetadata": false,
    "SwaggerClientId": "Arily_Swagger"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "xe7zeTf3oD0ikWGR"
  },
  "Redis": {
    "Configuration": "localhost:6379"
  },
  "ElasticApm": {
    "ServerUrl": "http://localhost:8200",
    "ServiceName": "arily-api",
    "Environment": "development",
    "TransactionSampleRate": 1.0,
    "CaptureBody": "all",
    "CaptureHeaders": true,
    "CentralConfig": false
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200",
    "LogRetentionDays": 7
  },
  "OpenIddict": {
    "Applications": {
      "Arily_Swagger": {
        "ClientId": "Arily_Swagger",
        "RootUrl": "https://localhost:44379"
      },
      "Arily_Test": {
        "ClientId": "Arily_Test",
        "ClientSecret": "test-secret",
        "RootUrl": "https://localhost:44379"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  }
}
